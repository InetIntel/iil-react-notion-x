name: Notify IIL Engine on Update

on:
  push:
    branches:
      - my-production # Binds strictly our custom production branch

jobs:
  ping-engine:
    runs-on: ubuntu-latest
    steps:
      - name: Trigger iil-site-engine Build
        run: |
          curl -H "Authorization: token ${{ secrets.ENGINE_DISPATCH_PAT }}" \
               -H "Accept: application/vnd.github.v3+json" \
               -X POST \
               -d '{"event_type": "submodule_updated"}' \
               https://api.github.com/repos/InetIntel/iil-site-engine/dispatches
